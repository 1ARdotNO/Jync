{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    "group:allNonMajor"
  ],
  "labels": ["dependencies"],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "rangeStrategy": "bump",
  "automerge": true,
  "platformAutomerge": true,
  "major": {
    "automerge": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 6am on monday"]
  },
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Heavy automerge for everything — the CI suite (build + Stalwart integration tests + CodeQL + Trivy) is the safety net, so anything that stays green merges itself.",
      "matchManagers": ["npm", "github-actions"],
      "automerge": true
    },
    {
      "description": "Group all GitHub Actions bumps into one PR.",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Hold TypeScript on v6 until typescript-eslint supports the v7 native compiler (v7 crashes our ESLint gate). Revisit when typescript-eslint ships TS7 support.",
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
